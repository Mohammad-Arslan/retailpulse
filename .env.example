APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Include every host you use in the browser (comma-separated).
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,localhost:5173,127.0.0.1,retailpulse.test,::1

# ---------------------------------------------------------------------------
# Docker published host ports (setup.sh auto-remaps on conflict)
# ---------------------------------------------------------------------------
APP_HOST_PORT=8000
REVERB_HOST_PORT=8080
VITE_HOST_PORT=5173
MYSQL_HOST_PORT=3306
REDIS_HOST_PORT=6379
MAILPIT_SMTP_HOST_PORT=1025
MAILPIT_UI_HOST_PORT=8025
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
PHPMYADMIN_HOST_PORT=8081

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database (Docker Compose: DB_HOST is overridden to "mysql" inside the app)
# MySQL container forbids MYSQL_USER=root — use a dedicated app user.
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=retailpulse
DB_USERNAME=retailpulse
DB_PASSWORD=secret

# Root password for the retailpulse-mysql container (docker-compose / entrypoint)
MYSQL_ROOT_PASSWORD=secret

# DB_CONNECTION=sqlite

# ---------------------------------------------------------------------------
# Session / queue / cache
# Inside Docker, compose forces redis for QUEUE_CONNECTION, CACHE_STORE, and
# SESSION_DRIVER so Horizon works. Values below are the host/template defaults.
# ---------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=retailpulse
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
# Browser connects to localhost; the Reverb process binds 0.0.0.0 inside Docker
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_CLIENT_HOST=localhost
REVERB_CLIENT_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Compose overrides REDIS_HOST to "redis" inside the app container
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Octane (production Docker target; ignored by local `php artisan serve`)
OCTANE_SERVER=frankenphp
# OCTANE_HTTPS=false

# ---------------------------------------------------------------------------
# Mail — Mailpit (SMTP :1025, UI http://localhost:8025)
# Compose overrides MAIL_HOST to "mailpit" inside the app container
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage for images)
# API :9000  ·  Console http://localhost:9001
# Compose overrides MINIO_ENDPOINT / AWS_ENDPOINT to http://minio:9000
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minioSecret
MINIO_ACCESS_KEY="${MINIO_ROOT_USER}"
MINIO_SECRET_KEY="${MINIO_ROOT_PASSWORD}"
MINIO_BUCKET=retailpulse
MINIO_REGION=us-east-1
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_URL=http://localhost:9000/retailpulse

# Mirrored for Laravel's s3 disk / AWS SDK clients
AWS_ACCESS_KEY_ID="${MINIO_ROOT_USER}"
AWS_SECRET_ACCESS_KEY="${MINIO_ROOT_PASSWORD}"
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=retailpulse
AWS_ENDPOINT=http://127.0.0.1:9000
AWS_URL=http://localhost:9000/retailpulse
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_EMAIL=admin@retailpulse.local
SUPER_ADMIN_PASSWORD=

# Laravel AI SDK
# Default provider for local development (ollama / deepseek / openai / …)
AI_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_API_KEY=
# Alias used by laravel/ai defaults (optional if OLLAMA_BASE_URL is set)
# OLLAMA_URL=http://127.0.0.1:11434

# DeepSeek (optional cloud fallback — never commit a real key)
DEEPSEEK_API_KEY=
DEEPSEEK_URL=https://api.deepseek.com
